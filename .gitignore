# Local directories generated by 'terraform init'
.terraform/

# Hide local state files (they can contain sensitive plain-text data like passwords)
*.tfstate
*.tfstate.*

# Exclude crash logs if a command fails
crash.log
crash.*.log

# Exclude all variable files containing actual secrets/credentials
*.tfvars
*.tfvars.json

# Exclude local override files used for testing
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude CLI configuration files
.terraformrc
terraform.rc